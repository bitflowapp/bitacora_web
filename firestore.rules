rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {

    // Gate de acceso por usuario (solo lee su propio doc)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // solo vos desde la consola
    }

    // (Opcional) Licencias: trial público o cualquier user logueado
    match /licenses/{id} {
      allow read: if id == "trial-demo" || request.auth != null;
      allow write: if false;
    }

    // Bloquear todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

